   "source": [
    "import numpy as np\n",
    "import time\n",
    "\n",
    "arr = np.ones((10000,10000))\n",
    "\n",
    "def npdot_time(arr):\n",
    "  start = time.time()\n",
    "  np.dot(arr, arr)\n",
    "  return time.time() - start\n",
    "\n",
    "npdot_time(arr)"
   ]
